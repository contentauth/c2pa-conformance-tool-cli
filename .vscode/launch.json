{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate PXL",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "testfiles/assets/PXL_20260208_202351558.jpg"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate PXL->Markdown",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "--format",
        "markdown",
        "testfiles/assets/PXL_20260208_202351558.jpg"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate PXL->HTML",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "--format",
        "html",
        "testfiles/assets/PXL_20260208_202351558.jpg"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate ChatGPT Image",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "testfiles/assets/ChatGPT_Image.png"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate Multiple Assets",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "testfiles/assets/PXL_20260208_202351558.jpg",
        "testfiles/assets/ChatGPT_Image.png"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate ChatGPT Image w/GenAI Profile",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "--profile",
        "testfiles/profiles/fully-generative-ai_profile.yml",
        "testfiles/assets/ChatGPT_Image.png"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate ChatGPT Image w/GenAI Profile - .md",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
        "filter": { "name": "c2pa-validate", "kind": "bin" }
      },
      "args": [
        "-o",
        "output",
        "--profile",
        "testfiles/profiles/fully-generative-ai_profile.yml",
        "--format",
        "markdown",
        "testfiles/assets/ChatGPT_Image.png"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Validate ChatGPT Image w/GenAI Profile - .html",
      "cargo": {
        "args": ["build", "--bin", "c2pa-validate"],
